# ── Django ──────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=*.railway.app,localhost,127.0.0.1

# ── Database ───────────────────────────────────────
# Railway provides DATABASE_URL automatically when you add a PostgreSQL plugin.
# The app auto-detects it. No need to set DB_* variables separately.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Admin Panel ────────────────────────────────────
PANEL_USERNAME=era
PANEL_PASSWORD_HASH=$2b$12$your_bcrypt_hash_here

# ── Telegram (optional) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
