{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InVision U — ML Pipeline Candidate Profile",
  "description": "Nested format consumed by the ML pipeline (feature_builder, scorer, explainer). Produced by transforming db_candidate_schema.json via data/loader.py. Fields marked 'card only' are passed to the commission dashboard but MUST NOT enter the scoring model.",
  "type": "object",
  "required": ["id", "personal", "education", "experience", "essay"],
  "properties": {

    "id": { "type": "string" },

    "personal": {
      "type": "object",
      "description": "Card only — shown to commission, never scored.",
      "required": ["name", "age"],
      "properties": {
        "name":        { "type": "string" },
        "age":         { "type": "integer", "minimum": 14, "maximum": 25 },
        "city":        { "type": ["string", "null"] },
        "region":      { "type": ["string", "null"] },
        "school_type": {
          "type": ["string", "null"],
          "enum": ["general", "lyceum", "gymnasium", "specialized", "homeschool", "college", "other", null]
        },
        "languages": {
          "type": "array",
          "description": "Card only — self-reported, not scored.",
          "items": { "type": "string" }
        }
      }
    },

    "education": {
      "type": "object",
      "description": "All fields here enter the scoring model (except where noted).",
      "required": ["gpa"],
      "properties": {
        "gpa": { "type": "number", "minimum": 0, "maximum": 5.0 },

        "ent_score": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 140,
          "description": "Normalized to 0-1 before entering model. null treated as 0 (not punished — candidate may not have taken ENT)."
        },
        "ielts_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 9.0,
          "description": "Normalized to 0-1. Reflects English proficiency relevant to university instruction language. null treated as 0."
        },

        "olympiads": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["subject", "level", "year"],
            "properties": {
              "subject": { "type": "string" },
              "level": {
                "type": "string",
                "enum": ["school", "city", "regional", "republican", "national", "international"]
              },
              "year":  { "type": "integer" },
              "prize": { "type": "boolean" }
            }
          }
        },

        "courses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "platform", "completed"],
            "properties": {
              "name":      { "type": "string" },
              "platform":  { "type": "string" },
              "year":      { "type": ["integer", "null"] },
              "completed": { "type": "boolean" }
            }
          }
        }
      }
    },

    "experience": {
      "type": "object",
      "properties": {
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "role", "year"],
            "properties": {
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["technical", "social", "media", "business", "education", "other"]
              },
              "role": {
                "type": "string",
                "enum": ["founder", "co_founder", "participant", "volunteer"]
              },
              "year":                    { "type": "integer" },
              "team_size":               { "type": ["integer", "null"], "minimum": 1 },
              "description":             { "type": ["string", "null"] },
              "failure_note":            { "type": ["string", "null"] },
              "continued_after_failure": { "type": ["boolean", "null"] }
            }
          }
        }
      }
    },

    "essay": {
      "type": "object",
      "properties": {
        "text":       { "type": ["string", "null"] },
        "word_count": { "type": ["integer", "null"] }
      }
    },

    "bot_metadata": {
      "type": "object",
      "description": "Automatically collected. fingerprint fields enter the model; funnel_stage is card only.",
      "properties": {
        "funnel_stage": {
          "type": "string",
          "enum": ["started", "consented", "education_done", "projects_done", "essay_done", "scenarios_done", "submitted", "abandoned"]
        },
        "fingerprint_display": {
          "type": ["object", "null"],
          "description": "5 SLPI cluster averages for dashboard and SHAP display.",
          "properties": {
            "model":     { "type": "number" },
            "inspire":   { "type": "number" },
            "challenge": { "type": "number" },
            "enable":    { "type": "number" },
            "encourage": { "type": "number" }
          }
        },
        "fingerprint_vector": {
          "type": ["array", "null"],
          "description": "500-dimensional vector entering XGBoost. null if fingerprint_reliable=false.",
          "items": { "type": "number" },
          "minItems": 500,
          "maxItems": 500
        },
        "fingerprint_reliable": { "type": "boolean" }
      }
    },

    "label": {
      "type": "string",
      "enum": ["shortlist", "maybe", "reject"],
      "description": "Human annotation — only present in training dataset, never in production."
    }
  }
}
