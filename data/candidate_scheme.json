{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InVision U Candidate Profile",
  "description": "Schema for candidate applications to InVision U. Demographic fields are for informational display only and MUST NOT be used in scoring.",
  "type": "object",
  "required": ["id", "personal", "education", "experience", "essay", "motivation", "self_assessment"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique candidate identifier (anonymized)"
    },
    "personal": {
      "type": "object",
      "description": "Personal info — shown to commission but NOT used in scoring",
      "required": ["name", "age"],
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "integer", "minimum": 14, "maximum": 25 },
        "city": { "type": "string" },
        "region": { "type": "string" },
        "school_type": {
          "type": "string",
          "enum": ["general", "lyceum", "gymnasium", "specialized", "homeschool", "college", "other"]
        },
        "has_mentor": { "type": "boolean" },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "education": {
      "type": "object",
      "required": ["gpa"],
      "properties": {
        "gpa": { "type": "number", "minimum": 0, "maximum": 5.0 },
        "favorite_subjects": {
          "type": "array",
          "items": { "type": "string" }
        },
        "olympiads": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["subject", "level", "result", "year"],
            "properties": {
              "subject": { "type": "string" },
              "level": {
                "type": "string",
                "enum": ["school", "city", "regional", "national", "international"]
              },
              "result": {
                "type": "string",
                "enum": ["participant", "honorable_mention", "prize"]
              },
              "year": { "type": "integer" }
            }
          }
        },
        "courses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "platform", "completed"],
            "properties": {
              "name": { "type": "string" },
              "platform": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      }
    },

    "experience": {
      "type": "object",
      "properties": {
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "role", "year"],
            "properties": {
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["technical", "social", "media", "business", "education", "other"]
              },
              "role": {
                "type": "string",
                "enum": ["founder", "co_founder", "participant", "volunteer"]
              },
              "year": { "type": "integer" },
              "is_active": { "type": "boolean" },
              "team_size": { "type": "integer", "minimum": 1 },
              "description": { "type": "string" }
            }
          }
        },
        "volunteering": {
          "type": "array",
          "items": { "type": "string" }
        },
        "leadership_roles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "motivation": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 50,
          "description": "Free-text answer: why InVision U?"
        }
      }
    },

    "essay": {
      "type": "object",
      "required": ["topic", "text", "word_count"],
      "properties": {
        "topic": { "type": "string" },
        "text": {
          "type": "string",
          "description": "Essay text, minimum 200 words"
        },
        "word_count": { "type": "integer", "minimum": 150 }
      }
    },

    "self_assessment": {
      "type": "object",
      "description": "Optional self-assessment on 1-5 scale. Used as additional signal, cross-validated against actual achievements.",
      "properties": {
        "leadership": { "type": "integer", "minimum": 1, "maximum": 5 },
        "teamwork": { "type": "integer", "minimum": 1, "maximum": 5 },
        "creativity": { "type": "integer", "minimum": 1, "maximum": 5 },
        "persistence": { "type": "integer", "minimum": 1, "maximum": 5 },
        "communication": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },

    "bot_metadata": {
      "type": "object",
      "description": "Automatically collected by Telegram bot — candidate does not see this",
      "properties": {
        "session_duration_sec": { "type": "integer" },
        "total_messages": { "type": "integer" },
        "essay_typing_duration_sec": { "type": "integer" },
        "voice_message_duration_sec": { "type": "integer" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "pauses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "after_state": { "type": "string" },
              "duration_sec": { "type": "integer" }
            }
          }
        },
        "referral_source": { "type": "string" },
        "funnel_stage": {
          "type": "string",
          "enum": ["started", "education_done", "projects_done", "essay_done", "completed", "abandoned"],
          "description": "How far the candidate got in the bot flow"
        }
      }
    },

    "label": {
      "type": "string",
      "enum": ["shortlist", "maybe", "reject"],
      "description": "Human annotation — only present in training dataset, never in production"
    }
  }
}
